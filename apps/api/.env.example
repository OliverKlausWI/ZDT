# ZDT API Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8080

# Ollama LLM
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b

# GLM-5 Canvas API (get your key from https://open.bigmodel.cn/)
GLM5_API_KEY=your-glm5-api-key

# Email (n8n Webhook)
N8N_EMAIL_WEBHOOK_URL=
N8N_EMAIL_KEY=

# TTS - Chatterbox (Host System)
TTS_URL=http://192.168.100.64:8004/tts
TTS_VOICE=Emily.wav

# TTS - Piper Fallback (optional)
PIPER_BIN=/usr/bin/piper-tts
PIPER_MODEL=
PIPER_CONFIG=

# ASR - Whisper (Host System)
ASR_URL=http://192.168.100.64:9002/transcribe
ASR_FIELD=file
